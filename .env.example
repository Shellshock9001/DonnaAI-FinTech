# ============================================
# Liquidity.ai FinTech â€” Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.

# â”€â”€ Server â”€â”€
PORT=3001

# â”€â”€ Security â”€â”€
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING

# â”€â”€ CORS â”€â”€
# Use * to allow all origins (for LAN sharing), or a specific URL for production
CORS_ORIGIN=*

# â”€â”€ Data â”€â”€
# Directory where the SQLite database is stored (relative to project root)
DATA_DIR=./data

# -- Email (Resend) --
# Sign up at resend.com to get your API key
# Go to API Keys and create a new key
# Use onboarding@resend.dev as FROM address until domain is verified
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM=onboarding@resend.dev

